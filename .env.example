# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxxxx.region.aws.neon.tech/dbname?sslmode=require"

# OpenClaw Integration (Optional)
OPENCLAW_API_URL="http://your-openclaw-instance:port"
OPENCLAW_API_KEY="your-openclaw-api-key"

# Expiring Perk Email Notifications
RESEND_API_KEY=""
PERK_ALERT_EMAIL="jayscotta@gmail.com"
PERK_ALERT_FROM="MaxPoints <perks@your-domain.com>"
CRON_SECRET="generate-a-long-random-secret"

# Web Push Notifications (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:your-email@example.com"

# App URL (Update for production)
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
